# ============================================================
# GC · Gestión de Cobranza — Variables de entorno
# Copiar a .env.local (desarrollo) y cargar en Vercel (producción).
# NUNCA commitear .env.local ni valores reales.
# ============================================================

# ---------- Supabase ----------
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role: SOLO servidor. Da acceso total a la base (bypass RLS).
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------- Aplicación ----------
# URL pública canónica de la app (con https, sin barra final)
NEXT_PUBLIC_APP_URL=https://www.tudominio.com

# Secreto de firma de las sesiones del portal del cliente (JWT HS256).
# Generar con: openssl rand -hex 32
PORTAL_SESSION_SECRET=

# Secreto para los endpoints de cron (backups, notificaciones).
# Generar con: openssl rand -hex 16 · Configurar el mismo valor en el cron de Vercel.
CRON_SECRET=

# ---------- Google Drive (fotos de cheques) · Service Account ----------
# Google Cloud → IAM → Service Accounts → crear + key JSON.
# Compartir la carpeta raíz de Drive con el email de la service account (permiso Editor).
GOOGLE_SERVICE_ACCOUNT_EMAIL=nombre@proyecto.iam.gserviceaccount.com
# La private key del JSON, con los saltos de línea como \n
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# ID de la carpeta raíz en Drive donde se guardan las fotos (de la URL de la carpeta)
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ---------- Gmail API (notificaciones por email) · OAuth ----------
# Google Cloud → Credentials → OAuth Client ID (tipo Web).
# El refresh token se obtiene autorizando la cuenta emisora (scope gmail.send).
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
# Casilla desde la que salen las notificaciones
GMAIL_USER=notificaciones@tudominio.com
